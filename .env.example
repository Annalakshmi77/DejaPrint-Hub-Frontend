# API Configuration
VITE_API_URL=http://localhost:3000/api/v1

# Payment Gateway (Razorpay)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
VITE_RAZORPAY_SECRET=your_razorpay_secret

# File Upload
VITE_MAX_FILE_SIZE=52428800
VITE_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,tiff,ai,eps,cdr,docx

# Email Configuration (for notifications)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your_email@gmail.com
VITE_SMTP_PASS=your_app_password

# Business Information
VITE_BUSINESS_NAME=PrintCraft
VITE_BUSINESS_EMAIL=info@printcraft.com
VITE_BUSINESS_PHONE=+91-XXXXXXXXXX
VITE_BUSINESS_ADDRESS=Your Business Address

# GST Information (if applicable)
VITE_GST_NUMBER=your_gst_number

# Maps (if needed)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Analytics
VITE_GOOGLE_ANALYTICS_ID=your_ga_id
VITE_SENTRY_DSN=your_sentry_dsn

# Feature Flags
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_QUOTATION=true
VITE_ENABLE_DESIGN_UPLOAD=true
VITE_ENABLE_BULK_ORDERS=true
